<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="livepaper.App"
             RequestedThemeVariant="Dark">

<Application.Resources>
        <SolidColorBrush x:Key="BgBase"    Color="#1e1e2e"/>
        <SolidColorBrush x:Key="BgMantle"  Color="#181825"/>
        <SolidColorBrush x:Key="BgCrust"   Color="#11111b"/>
        <SolidColorBrush x:Key="Surface0"  Color="#313244"/>
        <SolidColorBrush x:Key="Surface1"  Color="#45475a"/>
        <SolidColorBrush x:Key="Surface2"  Color="#585b70"/>
        <SolidColorBrush x:Key="TextColor" Color="#cdd6f4"/>
        <SolidColorBrush x:Key="Subtext"   Color="#a6adc8"/>
        <SolidColorBrush x:Key="Muted"     Color="#6c7086"/>
        <SolidColorBrush x:Key="Accent"      Color="#89b4fa"/>
        <SolidColorBrush x:Key="AccentFg"   Color="#1e1e2e"/>
        <SolidColorBrush x:Key="AccentHover" Color="#a8c7ff"/>
        <SolidColorBrush x:Key="Danger"     Color="#f38ba8"/>
        <SolidColorBrush x:Key="DangerBg"   Color="#3d1f24"/>
        <SolidColorBrush x:Key="Success"    Color="#a6e3a1"/>

        <!-- ScrollBar Overrides -->
        <SolidColorBrush x:Key="ScrollBarTrackFill" Color="Transparent" />
        <SolidColorBrush x:Key="ScrollBarTrackFillPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent" />
        <SolidColorBrush x:Key="ScrollBarBackgroundPointerOver" Color="Transparent" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <mi:MaterialIconStyles />

        <!-- Window -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource BgMantle}"/>
            <Setter Property="FontFamily" Value="Noto Sans,Inter,Cantarell,Liberation Sans,sans-serif"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Buttons -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.065"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.96)"/>
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentFg}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Danger}"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerBg}"/>
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Subtext}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Surface0}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        </Style>
        <Style Selector="Button.ghost:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Surface1}"/>
        </Style>

        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Surface1}"/>
            <Setter Property="Background" Value="{DynamicResource Surface0}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
        </Style>

        <!-- ComboBox -->
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Surface1}"/>
            <Setter Property="Background" Value="{DynamicResource Surface0}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- NumericUpDown -->
        <Style Selector="NumericUpDown">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Surface1}"/>
            <Setter Property="Background" Value="{DynamicResource Surface0}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Source pill ListBox -->
        <Style Selector="ListBox.pills">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBox.pills ListBoxItem">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Foreground" Value="{DynamicResource Subtext}"/>
            <Setter Property="Background" Value="{DynamicResource Surface0}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ListBox.pills ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentFg}"/>
        </Style>
        <Style Selector="ListBox.pills ListBoxItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource AccentFg}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="ListBox.pills ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Surface1}"/>
        </Style>

        <!-- Tab control — hide the underline, use foreground only -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- Hide the selected underline pipe -->
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Height" Value="2"/>
            <Setter Property="CornerRadius" Value="1"/>
            <Setter Property="Margin" Value="12,0"/>
        </Style>

        <!-- CheckBox -->
        <Style Selector="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
        </Style>

        <!-- Modal backdrop -->
        <Style Selector="Button.backdrop">
            <Setter Property="Background" Value="#B2000000"/>
        </Style>
        <Style Selector="Button.backdrop:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#B2000000"/>
        </Style>
        <Style Selector="Button.backdrop:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#B2000000"/>
        </Style>

        <!-- ScrollBar -->
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ScrollBar /template/ Rectangle#TrackRect">
            <Setter Property="Fill" Value="Transparent" />
        </Style>

        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="10"/>
            <Setter Property="MinHeight" Value="10"/>
        </Style>

        <Style Selector="ScrollBar /template/ RepeatButton#PART_LineUpButton,
                       ScrollBar /template/ RepeatButton#PART_LineDownButton,
                       ScrollBar /template/ RepeatButton#PART_PageUpButton,
                       ScrollBar /template/ RepeatButton#PART_PageDownButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <Style Selector="ScrollBar Thumb">
            <Setter Property="Background" Value="{DynamicResource Surface1}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.1"/>
                    <DoubleTransition Property="Height" Duration="0:0:0.1"/>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="ScrollBar:vertical Thumb">
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style Selector="ScrollBar:horizontal Thumb">
            <Setter Property="MinWidth" Value="20"/>
            <Setter Property="MinHeight" Value="6"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style Selector="ScrollBar:vertical:pointerover Thumb">
            <Setter Property="Background" Value="{DynamicResource Surface2}"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Margin" Value="1,0"/>
        </Style>
        <Style Selector="ScrollBar:horizontal:pointerover Thumb">
            <Setter Property="Background" Value="{DynamicResource Surface2}"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <Style Selector="ScrollBar:pressed Thumb">
            <Setter Property="Background" Value="{DynamicResource Muted}"/>
        </Style>

        <!-- Library card hover outline -->
        <Style Selector="Border Border.library-hover-outline">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border:pointerover Border.library-hover-outline">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <!-- Playlist strip item hover outline (scoped to playlist-item border only) -->
        <Style Selector="Border.playlist-item Border.playlist-item-hover">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.playlist-item:pointerover Border.playlist-item-hover">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

    </Application.Styles>
</Application>
