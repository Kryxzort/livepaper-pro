<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:livepaper.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:gif="clr-namespace:Avalonia.Labs.Gif;assembly=Avalonia.Labs.Gif"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="livepaper.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="livepaper"
        Width="1100" Height="720"
        MinWidth="640" MinHeight="480">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <ControlTemplate x:Key="ThumbnailDisplay" TargetType="TemplatedControl">
            <Panel x:DataType="vm:WallpaperCardViewModel">
                <asyncImageLoader:AdvancedImage
                    Source="{Binding ThumbnailSource}"
                    Stretch="UniformToFill"
                    RenderOptions.BitmapInterpolationMode="LowQuality"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <Viewbox IsVisible="{Binding IsGifActive}" Stretch="UniformToFill"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <gif:GifImage Source="{Binding ActiveGifSource}"/>
                </Viewbox>
            </Panel>
        </ControlTemplate>
    </Window.Resources>

    <Grid RowDefinitions="*,Auto,Auto">

            <TabControl Grid.Row="0" x:Name="MainTabControl">

                <!-- ── Browse ── -->
                <TabItem Header="Browse">
                    <DockPanel>

                        <!-- Top bar -->
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource BgBase}"
                                Padding="16,12"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource Surface0}">
                            <DockPanel>

                                <!-- Source pills -->
                                <ListBox DockPanel.Dock="Left"
                                         Classes="pills"
                                         ItemsSource="{Binding Sources}"
                                         SelectedItem="{Binding SelectedSource}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Right controls -->
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right">
                                    <TextBox Text="{Binding SearchQuery}"
                                             PlaceholderText="Search…"
                                             Width="220"
                                             IsEnabled="{Binding SelectedSource.SupportsSearch}">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}"/>
                                        </TextBox.KeyBindings>
                                    </TextBox>
                                    <Button Content="Search"
                                            Classes="ghost"
                                            Command="{Binding SearchCommand}"
                                            IsEnabled="{Binding SelectedSource.SupportsSearch}"/>
                                    <Button Classes="ghost"
                                            Width="28" Height="28" Padding="0"
                                            Command="{Binding LoadWallpapersCommand}"
                                            ToolTip.Tip="Refresh">
                                        <mi:MaterialIcon Kind="Refresh" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>

                            </DockPanel>
                        </Border>

                        <!-- Loading bar -->
                        <ProgressBar DockPanel.Dock="Top"
                                     IsIndeterminate="True"
                                     IsVisible="{Binding IsLoading}"
                                     Height="3" CornerRadius="0"/>

                        <!-- Selection toolbar -->
                        <Border DockPanel.Dock="Bottom"
                                IsVisible="{Binding AnyBrowseSelected}"
                                Background="{DynamicResource BgMantle}"
                                BorderBrush="{DynamicResource Surface0}"
                                BorderThickness="0,1,0,0"
                                Padding="16,10">
                            <DockPanel>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextColor}"
                                           FontSize="13"
                                           Text="{Binding BrowseSelectedCount, StringFormat='{}{0} selected'}"/>
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right">
                                    <Button Content="Download" Classes="accent"
                                            Command="{Binding DownloadSelectedCommand}"/>
                                    <Button Content="Cancel" Classes="ghost"
                                            Command="{Binding ClearBrowseSelectionCommand}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Wallpaper grid -->
                        <ScrollViewer x:Name="BrowseScrollViewer"
                                      HorizontalScrollBarVisibility="Disabled"
                                      AllowAutoHide="False">
                            <ItemsRepeater x:Name="BrowseItemsRepeater"
                                           ItemsSource="{Binding BrowseWallpapers}"
                                           Margin="10,0,0,0"
                                           VerticalCacheLength="1">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MinItemWidth="{Binding $parent[Window].DataContext.CardMinWidth}" ItemsStretch="Fill"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:WallpaperCardViewModel">
                                        <Border Margin="6" CornerRadius="10"
                                                ClipToBounds="True"
                                                Background="{DynamicResource BgBase}"
                                                PointerEntered="OnCardPointerEntered"
                                                PointerExited="OnCardPointerExited">
                                            <Grid RowDefinitions="Auto,*,Auto">

                                                <Panel Grid.Row="0"
                                                       Height="{Binding $parent[Window].DataContext.CardThumbnailHeight}">
                                                    <Button Padding="0"
                                                            Background="Transparent" BorderThickness="0"
                                                            HorizontalAlignment="Stretch"
                                                            CornerRadius="10,10,0,0" ClipToBounds="True"
                                                            Command="{Binding $parent[Window].DataContext.OpenPreviewCommand}"
                                                            CommandParameter="{Binding}">
                                                        <TemplatedControl Template="{StaticResource ThumbnailDisplay}"/>
                                                    </Button>
                                                    <!-- SCENE badge -->
                                                    <Border HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Margin="5,5,0,0"
                                                            IsVisible="{Binding IsScene}"
                                                            Background="{DynamicResource Accent}"
                                                            CornerRadius="4" Padding="4,2"
                                                            IsHitTestVisible="False">
                                                        <TextBlock Text="SCENE"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentFg}"/>
                                                    </Border>
                                                </Panel>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Title}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextColor}"
                                                           Margin="10,8,10,4"
                                                           FontSize="12"
                                                           MaxLines="2"/>

                                                <Button Grid.Row="2"
                                                        Content="Download &amp; Apply"
                                                        Classes="accent"
                                                        Margin="10,4,10,10"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{Binding $parent[Window].DataContext.DownloadCommand}"
                                                        CommandParameter="{Binding}"/>

                                                <!-- State overlays -->
                                                <Panel Grid.RowSpan="3" IsHitTestVisible="False">
                                                    <Border Classes="library-hover-outline"
                                                            BorderBrush="{DynamicResource Accent}"
                                                            BorderThickness="2.5"
                                                            CornerRadius="10"/>
                                                    <Border IsVisible="{Binding IsSelected}"
                                                            BorderBrush="{DynamicResource Accent}"
                                                            BorderThickness="2.5"
                                                            CornerRadius="10"/>
                                                </Panel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>

                    </DockPanel>
                </TabItem>

                <!-- ── Library ── -->
                <TabItem Header="Library">
                    <Grid>
                        <DockPanel>

                            <!-- Header -->
                            <Border DockPanel.Dock="Top"
                                    Background="{DynamicResource BgBase}"
                                    Padding="16,12"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource Surface0}">
                                <DockPanel>
                                    <TextBlock Text="Your downloaded wallpapers"
                                               Foreground="{DynamicResource Subtext}"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                Spacing="10"
                                                HorizontalAlignment="Right">
                                        <CheckBox Content="Shuffle"
                                                  IsChecked="{Binding ShuffleLibrary}"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Subtext}"/>
                                        <Button Content="Import"
                                                Classes="ghost"
                                                IsEnabled="{Binding !IsImporting}"
                                                Command="{Binding OpenImportCommand}"/>
                                        <Button Content="Stop"
                                                Classes="danger"
                                                Command="{Binding StopCommand}"/>
                                        <Button Content="Play All"
                                                Classes="accent"
                                                Command="{Binding PlayLibraryCommand}"/>
                                        <TextBox Text="{Binding LibrarySearchQuery}"
                                                 PlaceholderText="Search…"
                                                 Width="220"
                                                 VerticalAlignment="Center"/>
                                        <Button Classes="ghost"
                                                Width="28" Height="28" Padding="0"
                                                ToolTip.Tip="Sort">
                                            <Button.Flyout>
                                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                    <MenuItem Header="Name A–Z"
                                                              Command="{Binding SetLibrarySortCommand}"
                                                              CommandParameter="0"/>
                                                    <MenuItem Header="Name Z–A"
                                                              Command="{Binding SetLibrarySortCommand}"
                                                              CommandParameter="1"/>
                                                    <MenuItem Header="Videos first"
                                                              Command="{Binding SetLibrarySortCommand}"
                                                              CommandParameter="2"/>
                                                    <MenuItem Header="Scenes first"
                                                              Command="{Binding SetLibrarySortCommand}"
                                                              CommandParameter="3"/>
                                                    <MenuItem Header="Newest added"
                                                              Command="{Binding SetLibrarySortCommand}"
                                                              CommandParameter="4"/>
                                                    <MenuItem Header="Oldest added"
                                                              Command="{Binding SetLibrarySortCommand}"
                                                              CommandParameter="5"/>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                            <mi:MaterialIcon Kind="SortVariant" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>
                            </Border>


                            <!-- Selection toolbar (above playlist strip) -->
                            <Border DockPanel.Dock="Bottom"
                                    IsVisible="{Binding AnyLibrarySelected}"
                                    Background="{DynamicResource BgMantle}"
                                    BorderBrush="{DynamicResource Surface0}"
                                    BorderThickness="0,1,0,0"
                                    Padding="16,10">
                                <DockPanel>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextColor}"
                                               FontSize="13"
                                               Text="{Binding LibrarySelectedCount, StringFormat='{}{0} selected'}"/>
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                HorizontalAlignment="Right">
                                        <Button Content="Add to Playlist" Classes="ghost"
                                                Command="{Binding AddSelectedToPlaylistCommand}"/>
                                        <Button Content="Remove from Playlist" Classes="ghost"
                                                Command="{Binding RemoveSelectedFromPlaylistCommand}"/>
                                        <Button Content="Delete" Classes="danger"
                                                Command="{Binding DeleteSelectedCommand}"/>
                                        <Button Content="Cancel" Classes="ghost"
                                                Command="{Binding ClearLibrarySelectionCommand}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Library grid -->
                            <ScrollViewer x:Name="LibraryScrollViewer"
                                          HorizontalScrollBarVisibility="Disabled"
                                          AllowAutoHide="False">
                                <ItemsRepeater x:Name="LibraryItemsRepeater"
                                               ItemsSource="{Binding FilteredLibraryWallpapers}"
                                               Margin="10,0,0,0"
                                               VerticalCacheLength="1">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="{Binding $parent[Window].DataContext.CardMinWidth}" ItemsStretch="Fill"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WallpaperCardViewModel">
                                            <Border Margin="6" CornerRadius="10"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource BgBase}"
                                                    PointerEntered="OnCardPointerEntered"
                                                    PointerExited="OnCardPointerExited">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Add to Playlist"
                                                                  Command="{Binding AddToPlaylistCommand}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid RowDefinitions="Auto,*,Auto">

                                                    <!-- Thumbnail + badges -->
                                                    <Grid Grid.Row="0"
                                                          Height="{Binding $parent[Window].DataContext.CardThumbnailHeight}">
                                                        <Button Padding="0"
                                                                Background="Transparent" BorderThickness="0"
                                                                HorizontalAlignment="Stretch"
                                                                CornerRadius="10,10,0,0" ClipToBounds="True"
                                                                Command="{Binding $parent[Window].DataContext.OpenPreviewCommand}"
                                                                CommandParameter="{Binding}">
                                                            <TemplatedControl Template="{StaticResource ThumbnailDisplay}"/>
                                                        </Button>

                                                        <!-- SCENE badge -->
                                                        <Border HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="5,5,0,0"
                                                                IsVisible="{Binding IsScene}"
                                                                Background="{DynamicResource Accent}"
                                                                CornerRadius="4" Padding="4,2"
                                                                IsHitTestVisible="False">
                                                            <TextBlock Text="SCENE"
                                                                       FontSize="9" FontWeight="Bold"
                                                                       Foreground="{DynamicResource AccentFg}"/>
                                                        </Border>

                                                        <!-- Checkmark badge -->
                                                        <Button HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,5,5,0"
                                                                Width="24" Height="24"
                                                                CornerRadius="12" Padding="0"
                                                                BorderThickness="0"
                                                                Background="{DynamicResource BgCrust}"
                                                                Command="{Binding AddToPlaylistCommand}">
                                                            <TextBlock Text="{Binding CheckmarkText}"
                                                                       FontSize="12" FontWeight="Bold"
                                                                       Foreground="{DynamicResource Accent}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Button>
                                                    </Grid>

                                                    <Grid Grid.Row="1" Margin="10,8,10,4">
                                                        <Grid ColumnDefinitions="Auto,*">
                                                            <TextBlock Grid.Column="0"
                                                                       Text="⚠ "
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource Danger}"
                                                                       VerticalAlignment="Top"
                                                                       IsVisible="{Binding HasCrashed}"
                                                                       ToolTip.Tip="This scene crashed during playback"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Title}"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{DynamicResource TextColor}"
                                                                       FontSize="12"
                                                                       MaxLines="2"/>
                                                        </Grid>
                                                    </Grid>

                                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="10,4,10,10">
                                                        <Button Grid.Column="0"
                                                                Content="Apply"
                                                                Classes="accent"
                                                                HorizontalAlignment="Stretch"
                                                                Command="{Binding $parent[Window].DataContext.ApplyCommand}"
                                                                CommandParameter="{Binding}"/>
                                                        <Button Grid.Column="1"
                                                                Content="Delete"
                                                                Classes="danger"
                                                                Margin="6,0,0,0"
                                                                Command="{Binding $parent[Window].DataContext.DeleteCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>

                                                    <!-- State overlays -->
                                                    <Panel Grid.RowSpan="3" IsHitTestVisible="False">
                                                        <Border Classes="library-hover-outline"
                                                                BorderBrush="{DynamicResource Accent}"
                                                                BorderThickness="2.5"
                                                                CornerRadius="10"/>
                                                        <Border IsVisible="{Binding IsSelected}"
                                                                BorderBrush="{DynamicResource Accent}"
                                                                BorderThickness="2.5"
                                                                CornerRadius="10"/>
                                                        <Border IsVisible="{Binding HasCrashed}"
                                                                BorderBrush="{DynamicResource Danger}"
                                                                BorderThickness="2.5"
                                                                CornerRadius="10"/>
                                                    </Panel>

                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </ScrollViewer>

                        </DockPanel>

                        <!-- Playlist settings overlay -->
                        <Grid IsVisible="{Binding IsPlaylistSettingsOpen}"
                              Background="#B2000000">
                            <Border Background="{DynamicResource BgBase}" CornerRadius="12" Padding="24"
                                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Playlist Settings" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextColor}"/>

                                    <!-- Order -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="ORDER"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Muted}"
                                                   LetterSpacing="2"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ToggleButton Content="Sequential"
                                                          IsChecked="{Binding IsSequential}">
                                                <ToggleButton.Styles>
                                                    <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                        <Setter Property="Background" Value="{DynamicResource Accent}"/>
                                                    </Style>
                                                    <Style Selector="ToggleButton:checked">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentFg}"/>
                                                    </Style>
                                                </ToggleButton.Styles>
                                            </ToggleButton>
                                            <ToggleButton Content="Shuffle"
                                                          IsChecked="{Binding PlaylistShuffle}">
                                                <ToggleButton.Styles>
                                                    <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                        <Setter Property="Background" Value="{DynamicResource Accent}"/>
                                                    </Style>
                                                    <Style Selector="ToggleButton:checked">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentFg}"/>
                                                    </Style>
                                                </ToggleButton.Styles>
                                            </ToggleButton>
                                        </StackPanel>
                                    </StackPanel>

                                    <CheckBox Content="Override global rotation settings"
                                              IsChecked="{Binding OverrideGlobalSettings}"
                                              Foreground="{DynamicResource TextColor}"/>

                                    <!-- Interval (per-playlist override) -->
                                    <StackPanel Spacing="8" IsEnabled="{Binding OverrideGlobalSettings}">
                                        <TextBlock Text="SWITCH EVERY"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Muted}"
                                                   LetterSpacing="2"/>
                                        <CheckBox Content="Switch when video ends"
                                                  IsChecked="{Binding DisplayAdvanceOnVideoEnd}"
                                                  Foreground="{DynamicResource TextColor}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12"
                                                    IsEnabled="{Binding !DisplayAdvanceOnVideoEnd}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Hours" FontSize="12"
                                                           Foreground="{DynamicResource Subtext}"/>
                                                <NumericUpDown Value="{Binding DisplayIntervalHours}"
                                                               Minimum="0" Maximum="99"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Minutes" FontSize="12"
                                                           Foreground="{DynamicResource Subtext}"/>
                                                <NumericUpDown Value="{Binding DisplayIntervalMinutes}"
                                                               Minimum="0" Maximum="59"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Seconds" FontSize="12"
                                                           Foreground="{DynamicResource Subtext}"/>
                                                <NumericUpDown Value="{Binding DisplayIntervalSeconds}"
                                                               Minimum="0" Maximum="59"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <CheckBox Content="Wait for video to end before switching"
                                              IsChecked="{Binding DisplayWaitForVideoEnd}"
                                              Foreground="{DynamicResource TextColor}"/>

                                    <Button Content="Close"
                                            Classes="ghost"
                                            HorizontalAlignment="Right"
                                            Command="{Binding ClosePlaylistSettingsCommand}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </TabItem>

                <!-- ── Settings ── -->
                <TabItem Header="Settings">
                    <ScrollViewer x:Name="SettingsScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="28" Spacing="20">

                            <TextBlock Text="Playback"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgBase}" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="12">
                                    <CheckBox Content="Loop" IsChecked="{Binding Loop}"
                                              Foreground="{DynamicResource TextColor}"/>
                                    <CheckBox Content="Mute audio" IsChecked="{Binding NoAudio}"
                                              Foreground="{DynamicResource TextColor}"/>
                                    <CheckBox Content="Disable cache" IsChecked="{Binding DisableCache}"
                                              Foreground="{DynamicResource TextColor}"/>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0"
                                          IsEnabled="{Binding !NoAudio}">
                                        <TextBlock Grid.Column="0" Text="Volume"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextColor}"
                                                   Width="80"/>
                                        <Slider Grid.Column="1"
                                                Minimum="0" Maximum="100"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding Volume}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Volume}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Subtext}"
                                                   Width="30" TextAlignment="Right"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0">
                                        <TextBlock Grid.Column="0" Text="Speed"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextColor}"
                                                   Width="80"/>
                                        <Slider Grid.Column="1"
                                                Minimum="0.1" Maximum="4"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding Speed}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Speed, StringFormat='{}{0:F1}x'}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Subtext}"
                                                   Width="36" TextAlignment="Right"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="PLAYLIST"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgBase}" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="12">
                                    <CheckBox Content="Switch when video ends"
                                              IsChecked="{Binding GlobalAdvanceOnVideoEnd}"
                                              Foreground="{DynamicResource TextColor}"/>
                                    <CheckBox Content="Wait for video to end before switching"
                                              IsChecked="{Binding GlobalWaitForVideoEnd}"
                                              Foreground="{DynamicResource TextColor}"/>
                                    <StackPanel Spacing="6"
                                                IsEnabled="{Binding !GlobalAdvanceOnVideoEnd}">
                                        <TextBlock Text="SWITCH EVERY"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Muted}"
                                                   LetterSpacing="2"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Hours" FontSize="12"
                                                           Foreground="{DynamicResource Subtext}"/>
                                                <NumericUpDown Value="{Binding GlobalIntervalHours}"
                                                               Minimum="0" Maximum="99"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Minutes" FontSize="12"
                                                           Foreground="{DynamicResource Subtext}"/>
                                                <NumericUpDown Value="{Binding GlobalIntervalMinutes}"
                                                               Minimum="0" Maximum="59"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Seconds" FontSize="12"
                                                           Foreground="{DynamicResource Subtext}"/>
                                                <NumericUpDown Value="{Binding GlobalIntervalSeconds}"
                                                               Minimum="0" Maximum="59"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="AUTO-MUTE"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgBase}" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="12">
                                    <CheckBox Content="Mute when system audio plays"
                                              IsChecked="{Binding AutoMute}"
                                              Foreground="{DynamicResource TextColor}"/>
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,12,Auto,12,Auto"
                                          IsEnabled="{Binding AutoMute}">
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Mute after"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextColor}"
                                                   Margin="0,0,16,0"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                       Value="{Binding AutoMuteDelayMs}"
                                                       Minimum="0" Maximum="30000" Increment="100"
                                                       FormatString="0"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                   Text="ms" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Subtext}"
                                                   Margin="8,0,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="Unmute after"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextColor}"
                                                   Margin="0,0,16,0"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                       Value="{Binding AutoUnmuteDelayMs}"
                                                       Minimum="0" Maximum="30000" Increment="100"
                                                       FormatString="0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2"
                                                   Text="ms" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Subtext}"
                                                   Margin="8,0,0,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0"
                                                   Text="Minimum level"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextColor}"
                                                   Margin="0,0,16,0"/>
                                        <NumericUpDown Grid.Row="4" Grid.Column="1"
                                                       Value="{Binding AutoMuteThresholdDb}"
                                                       Minimum="-80" Maximum="0" Increment="1"
                                                       FormatString="0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="2"
                                                   Text="dB" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Subtext}"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="MEMORY"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgBase}" CornerRadius="10" Padding="16">
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,12,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Demuxer max bytes"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextColor}"
                                               Margin="0,0,16,0"/>
                                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                   Value="{Binding DemuxerMaxBytes}"
                                                   Minimum="1" Maximum="10000" Increment="1"
                                                   FormatString="0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                               Text="MiB" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Subtext}"
                                               Margin="8,0,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Demuxer max back bytes"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextColor}"
                                               Margin="0,0,16,0"/>
                                    <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                   Value="{Binding DemuxerMaxBackBytes}"
                                                   Minimum="1" Maximum="10000" Increment="1"
                                                   FormatString="0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2"
                                               Text="MiB" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Subtext}"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="RENDERING"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgBase}" CornerRadius="10" Padding="16">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,12,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Hardware decoding"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextColor}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              ItemsSource="{Binding HwDecOptions}"
                                              SelectedItem="{Binding HwDec}"
                                              Width="130"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Video scale"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextColor}"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1"
                                              ItemsSource="{Binding VideoScaleOptions}"
                                              SelectedItem="{Binding VideoScale}"
                                              Width="130"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="BEHAVIOR"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgBase}" CornerRadius="10" Padding="16">
                                <CheckBox Content="Resume from last wallpaper"
                                          IsChecked="{Binding ResumeFromLast}"
                                          Foreground="{DynamicResource TextColor}"/>
                            </Border>

                            <TextBlock Text="SOURCES"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgBase}" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Wallpaper Engine workshop folder"
                                               Foreground="{DynamicResource TextColor}"/>
                                    <Grid ColumnDefinitions="*,Auto" >
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding WallpaperEnginePath}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Subtext}"
                                                   ToolTip.Tip="{Binding WallpaperEnginePath}"
                                                   Margin="0,0,8,0"/>
                                        <Button Grid.Column="1"
                                                Content="Browse"
                                                Classes="ghost"
                                                Command="{Binding PickWallpaperEngineFolderCommand}"/>
                                    </Grid>
                                    <CheckBox Content="Copy files instead of symlinking"
                                              IsChecked="{Binding WeCopyFiles}"
                                              Foreground="{DynamicResource TextColor}"/>
                                    <CheckBox Content="Allow scene support (experimental)"
                                              IsChecked="{Binding AllowScenes}"
                                              Foreground="{DynamicResource TextColor}"/>

                                    <!-- Monitor settings (only when scenes enabled) -->
                                    <StackPanel IsVisible="{Binding AllowScenes}" Spacing="8" Margin="0,4,0,0">
                                        <TextBlock Text="Monitors"
                                                   Foreground="{DynamicResource Subtext}"
                                                   FontSize="12"/>
                                        <Border Background="{DynamicResource BgCrust}"
                                                CornerRadius="8" Padding="10,8">
                                            <TextBlock TextWrapping="Wrap"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Subtext}">
                                                Input the names of the monitors you want scenes to be played on. On Hyprland, run <Run FontFamily="Monospace" Foreground="{DynamicResource Accent}">hyprctl monitors</Run> to list your monitors and their names. Find the equivalent command for your compositor.
                                            </TextBlock>
                                        </Border>

                                        <!-- Monitor selector row -->
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding LweMonitors}"
                                                      SelectedItem="{Binding SelectedLweMonitor}"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{DynamicResource TextColor}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Grid.Column="1"
                                                    Content="+"
                                                    Classes="ghost"
                                                    Margin="4,0,0,0"
                                                    Command="{Binding StartAddMonitorCommand}"
                                                    IsVisible="{Binding !IsAddingMonitor}"/>
                                            <Button Grid.Column="2"
                                                    Content="✕"
                                                    Classes="ghost"
                                                    Margin="4,0,0,0"
                                                    Command="{Binding RemoveSelectedMonitorCommand}"
                                                    IsVisible="{Binding SelectedLweMonitor, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        </Grid>

                                        <!-- Add monitor row -->
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              IsVisible="{Binding IsAddingMonitor}">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding NewMonitorName}"
                                                     PlaceholderText="e.g. DP-1"
                                                     Foreground="{DynamicResource TextColor}"/>
                                            <Button Grid.Column="1"
                                                    Content="Add"
                                                    Classes="accent"
                                                    Margin="4,0,0,0"
                                                    Command="{Binding ConfirmAddMonitorCommand}"/>
                                            <Button Grid.Column="2"
                                                    Content="Cancel"
                                                    Classes="ghost"
                                                    Margin="4,0,0,0"
                                                    Command="{Binding CancelAddMonitorCommand}"/>
                                        </Grid>

                                        <!-- Per-monitor settings -->
                                        <StackPanel IsVisible="{Binding SelectedLweMonitor, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                    Spacing="8"
                                                    Margin="0,4,0,0">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0"
                                                           Text="FPS"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextColor}"
                                                           Margin="0,0,12,0"/>
                                                <NumericUpDown Grid.Column="1"
                                                              Value="{Binding SelectedMonitorFps}"
                                                              Minimum="1"
                                                              Increment="1"
                                                              FormatString="0"
                                                              Foreground="{DynamicResource TextColor}"/>
                                            </Grid>
                                            <CheckBox Content="Primary (better audio sync)"
                                                      IsChecked="{Binding SelectedMonitorIsPrimary}"
                                                      Foreground="{DynamicResource TextColor}"/>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="*,Auto"
                                              ToolTip.Tip="How long to wait after launching a scene before killing the previous wallpaper">
                                            <TextBlock Grid.Column="0" Text="Transition delay (ms)"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextColor}"/>
                                            <NumericUpDown Grid.Column="1" Value="{Binding SceneTransitionDelayMs}"
                                                           Minimum="0" Maximum="5000" Increment="50"
                                                           Width="120" FormatString="0"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="APPEARANCE"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgBase}" CornerRadius="10" Padding="16">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,12,Auto,12,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Theme"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextColor}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              ItemsSource="{Binding Themes}"
                                              SelectedItem="{Binding SelectedTheme}"
                                              Width="220">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Thumbnail aspect"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextColor}"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1"
                                              ItemsSource="{Binding ThumbnailAspectOptions}"
                                              SelectedItem="{Binding ThumbnailAspect}"
                                              Width="130" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="Card size"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextColor}"/>
                                    <ComboBox Grid.Row="4" Grid.Column="1"
                                              ItemsSource="{Binding CardSizeOptions}"
                                              SelectedItem="{Binding CardSize}"
                                              Width="130" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="COMMAND PREVIEW"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgCrust}" CornerRadius="10" Padding="14">
                                <TextBlock Text="{Binding MpvOptionsPreview}"
                                           FontFamily="Monospace"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Accent}"/>
                            </Border>

                            <TextBlock Text="KEYBINDS"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgCrust}" CornerRadius="10" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Bind these commands in your compositor config:"
                                               Foreground="{DynamicResource Subtext}"
                                               FontSize="12"/>
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Toggle mute"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="livepaper --action=toggle-mute"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=toggle-mute"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Toggle pause"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="livepaper --action=toggle-pause"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=toggle-pause"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Stop"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1"
                                                   Text="livepaper --action=stop"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="4" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=stop"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Play (restore)"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1"
                                                   Text="livepaper --action=play"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="6" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=play"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Toggle stop/play"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1"
                                                   Text="livepaper --action=toggle-play"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="8" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=toggle-play"/>

                                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Next wallpaper"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="10" Grid.Column="1"
                                                   Text="livepaper --action=next-wallpaper"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="10" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=next-wallpaper"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Previous wallpaper"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1"
                                                   Text="livepaper --action=previous-wallpaper"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="12" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=previous-wallpaper"/>

                                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Random wallpaper"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="14" Grid.Column="1"
                                                   Text="livepaper --action=random"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="14" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=random"/>

                                        <TextBlock Grid.Row="16" Grid.Column="0" Text="Volume up"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="16" Grid.Column="1"
                                                   Text="livepaper --action=volume-up"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="16" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=volume-up"/>

                                        <TextBlock Grid.Row="18" Grid.Column="0" Text="Volume down"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="18" Grid.Column="1"
                                                   Text="livepaper --action=volume-down"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="18" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=volume-down"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="AUTOSTART"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{DynamicResource BgCrust}" CornerRadius="10" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Add this to your compositor's autostart to restore your wallpaper on login:"
                                               Foreground="{DynamicResource Subtext}"
                                               FontSize="12"/>
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Restore wallpaper"
                                                   Foreground="{DynamicResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="livepaper --restore"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --restore"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Reset to Defaults"
                                        Classes="ghost"
                                        Command="{Binding ResetMpvOptionsCommand}"/>
                                <Button Content="Clear Library"
                                        Classes="danger"
                                        Command="{Binding OpenClearLibraryCommand}"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

        <!-- Playlist panel -->
        <Border x:Name="PlaylistPanel"
                Grid.Row="1"
                IsVisible="False"
                Background="{DynamicResource BgMantle}"
                BorderBrush="{DynamicResource Surface0}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="0,8,0,0">

                <!-- Playlist header -->
                <DockPanel DockPanel.Dock="Top" Margin="12,0,12,8">
                    <TextBlock Text="PLAYLIST"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource Muted}"
                               LetterSpacing="2"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Spacing="6"
                                HorizontalAlignment="Right">
                        <Button Classes="ghost"
                                Width="28" Height="28" Padding="0"
                                ToolTip.Tip="Playlist Settings"
                                Command="{Binding TogglePlaylistSettingsCommand}">
                            <mi:MaterialIcon Kind="Tune" Width="16" Height="16"/>
                        </Button>
                        <Button Classes="ghost"
                                Width="28" Height="28" Padding="0"
                                ToolTip.Tip="Load Playlist"
                                Command="{Binding OpenLoadPlaylistCommand}">
                            <mi:MaterialIcon Kind="FolderOpen" Width="16" Height="16"/>
                        </Button>
                        <Button Classes="ghost"
                                Width="28" Height="28" Padding="0"
                                ToolTip.Tip="Save Playlist"
                                Command="{Binding OpenSavePlaylistCommand}">
                            <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16"/>
                        </Button>
                        <Button Classes="accent"
                                Padding="10,0" Height="28"
                                Command="{Binding PlayCustomPlaylistCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <mi:MaterialIcon Kind="Play" Width="14" Height="14"/>
                                <TextBlock Text="Play" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- Empty state -->
                <TextBlock IsVisible="{Binding IsPlaylistEmpty}"
                           Text="Add wallpapers using the + button on each card"
                           Foreground="{DynamicResource Muted}"
                           FontSize="12"
                           Margin="12,0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <!-- Playlist thumbnails -->
                <Grid IsVisible="{Binding !IsPlaylistEmpty}">
                    <ScrollViewer x:Name="PlaylistScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  AllowAutoHide="False">
                    <ItemsControl x:Name="PlaylistItemsControl"
                                  ItemsSource="{Binding PlaylistItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:WallpaperCardViewModel">
                                <Border Width="100" CornerRadius="6"
                                        ClipToBounds="True"
                                        Background="{DynamicResource BgBase}">
                                    <Grid Height="90">
                                        <asyncImageLoader:AdvancedImage
                                            Source="{Binding ThumbnailSource}"
                                            Stretch="UniformToFill"
                                            Width="100" Height="90"/>
                                        <Border Background="#99000000"
                                                VerticalAlignment="Bottom"
                                                Padding="4,2">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="10"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                        <Button HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,5,5,0"
                                                Width="24" Height="24"
                                                CornerRadius="12" Padding="0"
                                                BorderThickness="0"
                                                Background="{DynamicResource BgCrust}"
                                                Command="{Binding $parent[Window].DataContext.RemoveFromPlaylistCommand}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="−"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{DynamicResource Accent}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                    <!-- Drop position indicator -->
                    <Border x:Name="PlaylistDropIndicator"
                            Width="2" CornerRadius="1"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource Accent}"
                            IsHitTestVisible="False"
                            IsVisible="False"/>
                </Grid>

            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgCrust}"
                Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource Muted}"
                       FontSize="11"/>
        </Border>

        <!-- Download progress modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsDownloading}" Background="#B2000000">
            <Border Background="{DynamicResource BgBase}" CornerRadius="12" Padding="28"
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Downloading" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"/>
                    <TextBlock Text="{Binding DownloadTitle}" FontSize="12"
                               Foreground="{DynamicResource Subtext}"
                               TextTrimming="CharacterEllipsis"/>
                    <ProgressBar Value="{Binding DownloadProgress}"
                                 Minimum="0" Maximum="1"
                                 IsIndeterminate="{Binding DownloadIndeterminate}"
                                 Height="6" CornerRadius="3"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource Muted}"
                               HorizontalAlignment="Right">
                        <TextBlock.Text>
                            <Binding Path="DownloadProgress" StringFormat="{}{0:P0}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Image preview modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding PreviewCard, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Button Classes="backdrop"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    BorderThickness="0"
                    Command="{Binding ClosePreviewCommand}"/>

            <Border Background="{DynamicResource BgBase}" CornerRadius="12" Padding="16"
                    MaxWidth="860" MaxHeight="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid RowDefinitions="*,Auto,Auto,Auto,Auto">

                    <Panel Grid.Row="0" DataContext="{Binding PreviewCard}"
                           x:DataType="vm:WallpaperCardViewModel"
                           MaxWidth="828" MaxHeight="500">
                        <asyncImageLoader:AdvancedImage
                            IsVisible="{Binding !IsGifThumbnail}"
                            Source="{Binding ThumbnailSource}"
                            Stretch="Uniform"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Viewbox IsVisible="{Binding IsGifThumbnail}" Stretch="Uniform"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <gif:GifImage Source="{Binding GifSource}"/>
                        </Viewbox>
                    </Panel>

                    <!-- Crash warning -->
                    <Border Grid.Row="1"
                            IsVisible="{Binding PreviewCard.HasCrashed}"
                            Background="#20f38ba8"
                            CornerRadius="8" Padding="12,8" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="This scene crashed during playback"
                                           Foreground="{DynamicResource Danger}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="Removed from your playlist. Whitelist it to keep it there even when it crashes."
                                           Foreground="{DynamicResource Subtext}"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      Content="Whitelist"
                                      IsChecked="{Binding PreviewCard.IsWhitelisted}"
                                      Foreground="{DynamicResource TextColor}"
                                      VerticalAlignment="Center"
                                      Margin="12,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Per-wallpaper volume override -->
                    <Border Grid.Row="2"
                            IsVisible="{Binding PreviewCard.LibraryItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="{DynamicResource BgCrust}"
                            CornerRadius="8" Padding="12,8" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Volume"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextColor}"
                                       Width="56"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="100"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding PreviewCard.SliderVolume}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PreviewCard.SliderVolume}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Subtext}"
                                       Width="30" TextAlignment="Right"
                                       Margin="8,0,0,0"/>
                            <Button Grid.Column="3"
                                    Content="↺ Global"
                                    Classes="ghost"
                                    FontSize="11"
                                    Padding="10,6"
                                    Margin="8,0,0,0"
                                    IsVisible="{Binding !PreviewCard.IsVolumeSynced}"
                                    ToolTip.Tip="Reset to global volume"
                                    Command="{Binding PreviewCard.SyncToGlobalCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Per-wallpaper speed override -->
                    <Border Grid.Row="3"
                            IsVisible="{Binding PreviewCard.LibraryItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="{DynamicResource BgCrust}"
                            CornerRadius="8" Padding="12,8" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Speed"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextColor}"
                                       Width="56"/>
                            <Slider Grid.Column="1"
                                    Minimum="0.1" Maximum="4"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding PreviewCard.SliderSpeed}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PreviewCard.SliderSpeed, StringFormat='{}{0:F1}x'}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Subtext}"
                                       Width="36" TextAlignment="Right"
                                       Margin="8,0,0,0"/>
                            <Button Grid.Column="3"
                                    Content="↺ Global"
                                    Classes="ghost"
                                    FontSize="11"
                                    Padding="10,6"
                                    Margin="8,0,0,0"
                                    IsVisible="{Binding !PreviewCard.IsSpeedSynced}"
                                    ToolTip.Tip="Reset to global speed"
                                    Command="{Binding PreviewCard.SyncSpeedToGlobalCommand}"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PreviewCard.Title}"
                                       Foreground="{DynamicResource TextColor}"
                                       FontSize="13" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding PreviewCard.VideoDuration}"
                                       IsVisible="{Binding PreviewCard.VideoDuration, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{DynamicResource Subtext}"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Download &amp; Apply"
                                Classes="accent"
                                Margin="8,0,0,0"
                                IsVisible="{Binding PreviewCard.LibraryItem, Converter={x:Static ObjectConverters.IsNull}}"
                                Command="{Binding DownloadCommand}"
                                CommandParameter="{Binding PreviewCard}"/>
                        <Button Grid.Column="1"
                                Content="Apply"
                                Classes="accent"
                                Margin="8,0,0,0"
                                IsVisible="{Binding PreviewCard.LibraryItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Command="{Binding ApplyCommand}"
                                CommandParameter="{Binding PreviewCard}"/>
                        <Button Grid.Column="2"
                                Content="Close"
                                Classes="ghost"
                                Margin="8,0,0,0"
                                Command="{Binding ClosePreviewCommand}"/>
                    </Grid>

                </Grid>
            </Border>
        </Grid>

        <!-- Error modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
              Background="#B2000000">
            <Border Background="{DynamicResource BgBase}" CornerRadius="12" Padding="28"
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding ErrorTitle}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                               Foreground="{DynamicResource TextColor}"
                               TextWrapping="Wrap"/>
                    <Button Content="OK" Classes="ghost" HorizontalAlignment="Right"
                            Command="{Binding DismissErrorCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Clear library confirmation modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsClearLibraryOpen}" Background="#B2000000">
            <Border Background="{DynamicResource BgBase}" CornerRadius="12" Padding="28"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Clear Library" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource Danger}"/>
                    <TextBlock Text="This will permanently delete all downloaded wallpapers from disk. This cannot be undone."
                               FontSize="12" Foreground="{DynamicResource TextColor}" TextWrapping="Wrap"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource Muted}"
                               IsVisible="{Binding !ClearLibraryReady}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="You can confirm in {0}s…">
                                <Binding Path="ClearLibraryCountdown"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="ghost"
                                Command="{Binding CancelClearLibraryCommand}"/>
                        <Button Content="Delete All" Classes="danger"
                                IsEnabled="{Binding ClearLibraryReady}"
                                Command="{Binding ConfirmClearLibraryCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Save playlist modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsSavePlaylistOpen}" Background="#B2000000">
            <Border Background="{DynamicResource BgBase}" CornerRadius="12" Padding="24"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Save Playlist" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="NAME"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Muted}"
                                   LetterSpacing="2"/>
                        <AutoCompleteBox Text="{Binding SavePlaylistName, Mode=TwoWay}"
                                         ItemsSource="{Binding AvailablePlaylists}"
                                         MinimumPrefixLength="0"
                                         FilterMode="ContainsOrdinalCaseSensitive"
                                         PlaceholderText="My playlist"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="ghost"
                                Command="{Binding CancelSavePlaylistCommand}"/>
                        <Button Content="Save" Classes="accent"
                                IsDefault="True"
                                Command="{Binding ConfirmSavePlaylistCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Load playlist modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsLoadPlaylistOpen}" Background="#B2000000">
            <Border Background="{DynamicResource BgBase}" CornerRadius="12" Padding="24"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Load Playlist" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="PLAYLIST"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Muted}"
                                   LetterSpacing="2"/>
                        <ComboBox ItemsSource="{Binding AvailablePlaylists}"
                                  SelectedItem="{Binding SelectedPlaylistToLoad}"
                                  HorizontalAlignment="Stretch"
                                  IsVisible="{Binding AvailablePlaylists.Count}"/>
                        <TextBlock Text="No saved playlists"
                                   FontSize="12"
                                   Foreground="{DynamicResource Muted}"
                                   IsVisible="{Binding !AvailablePlaylists.Count}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="ghost"
                                Command="{Binding CancelLoadPlaylistCommand}"/>
                        <Button Content="Load" Classes="accent"
                                IsDefault="True"
                                IsEnabled="{Binding SelectedPlaylistToLoad, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Command="{Binding ConfirmLoadPlaylistCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Import wallpaper modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsImportOpen}" Background="#B2000000">
            <Border Background="{DynamicResource BgBase}" CornerRadius="12" Padding="24"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Import Wallpaper" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="TITLE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Muted}"
                                   LetterSpacing="2"/>
                        <TextBox Text="{Binding ImportTitle}"
                                 PlaceholderText="My wallpaper"/>
                        <TextBlock Text="A thumbnail will be auto-generated from the video."
                                   FontSize="11"
                                   Foreground="{DynamicResource Muted}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="ghost"
                                Command="{Binding CancelImportCommand}"/>
                        <Button Content="Import" Classes="accent"
                                IsDefault="True"
                                IsEnabled="{Binding !IsImporting}"
                                Command="{Binding ConfirmImportCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Drag preview (floats with cursor) -->
        <Canvas x:Name="DragPreviewCanvas"
                Grid.RowSpan="3"
                IsHitTestVisible="False"
                IsVisible="False">
            <Border x:Name="DragPreviewBorder"
                    Width="100" Height="90"
                    CornerRadius="4"
                    ClipToBounds="True"
                    Opacity="0.85"/>
        </Canvas>

    </Grid>
</Window>
